NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_CREDENTIALS=false
MONGODB_URI=mongodb://127.0.0.1:27017/daometer
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_COMMITMENT=confirmed
WORKER_EXECUTOR_SECRET_KEY=
WORKER_SIMULATE_BEFORE_EXECUTE=true
JWT_ACCESS_SECRET=replace-with-access-secret-minimum-32-chars
JWT_REFRESH_SECRET=replace-with-refresh-secret-minimum-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
BCRYPT_SALT_ROUNDS=12
WORKER_POLL_INTERVAL_MS=4000
WORKER_MAX_JOBS_PER_TICK=10
WORKER_LOCK_TIMEOUT_MS=120000
WORKER_MAX_RETRIES=5
WORKER_RETRY_DELAY_MS=10000
AUTO_EXECUTION_DEFAULT_RISK_SCORE=70
RESEND_API_KEY=
RESEND_FROM_EMAIL=
